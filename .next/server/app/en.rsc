9:["$","$La",null,{"formats":"$undefined","locale":"en","messages":{"Metadata":{"title":"Yonghejian | Precision Hardware","description":"Yonghejian specializes in precision hardware mold design, development, production and sales. One-stop solutions for precision mold R&D, hardware component manufacturing, and equipment customization in Dongguan, China.","keywords":"precision hardware, mold design, hardware manufacturing, CNC machining, custom mold, industrial equipment, hardware export, Dongguan, China manufacturer"},"MetadataProjects":{"title":"Products & Projects | Yonghejian Precision Hardware","description":"Explore Yonghejian's precision hardware projects: custom mold design, hardware component mass production, industrial machinery customization, and import/export trade solutions."},"MetadataPartners":{"title":"Partners | Yonghejian Precision Hardware","description":"Yonghejian's long-term partnerships with leading enterprises in raw materials, equipment, automation, and international trade across the precision hardware industry."},"MetadataAbout":{"title":"About Us | Yonghejian Precision Hardware","description":"Founded in 2016, Yonghejian is a high-tech enterprise in Dongguan, China specializing in precision hardware mold design, development, production and sales with ISO9001 certification."},"MetadataContact":{"title":"Contact Us | Yonghejian Precision Hardware","description":"Contact Yonghejian for precision hardware customization, mold development, equipment procurement, and import/export inquiries. Located in Dongguan, Guangdong, China."},"Nav":{"logo":"Yonghejian","home":"Home","projects":"Products","partners":"Partners","about":"About","contact":"Contact","themeToggle":"Toggle theme","cta":"Contact Us"},"LocaleSwitcher":{"en":"English","zh":"中文","label":"Switch language"},"HomePage":{"heroTitle":"Precision Hardware Manufacturing<br />Driving Industrial Upgrade","heroSubtitle":"One-stop solutions for precision mold R&D, hardware component production, equipment customization, and import/export","heroCta":"View Products","heroContact":"Contact Us","servicesTitle":"Core Services","servicesSubtitle":"With superb craftsmanship and professional technology, we provide one-stop precision hardware solutions for global clients","service1Title":"Precision Mold Design","service1Desc":"From concept to mold成型, providing full-process precision mold design, simulation analysis and process optimization","service2Title":"Hardware Component Manufacturing","service2Desc":"Advanced CNC machining centers and automated production lines for high-precision hardware component mass production","service3Title":"Machinery Equipment R&D","service3Desc":"In-house industrial machinery development with full technical support from design to installation and commissioning","service4Title":"Import & Export Trade","service4Desc":"Professional foreign trade team providing hardware product import/export and technical services","projectsTitle":"Featured Products","projectsSubtitle":"Selected cases in precision hardware manufacturing, mold R&D and equipment customization","projectsCta":"View All Products","testimonialsTitle":"Client Testimonials","ctaTitle":"Let's Start a Partnership","ctaText":"For precision hardware customization, mold development or equipment customization services, feel free to contact us","ctaButton":"Inquire Now"},"AboutPage":{"heroTitle":"Precision Hardware Manufacturing Crafted with Excellence","heroText":"Founded in 2016, Yonghejian is a high-tech enterprise integrating precision hardware mold design, development, production and sales. Located in Dongguan, Guangdong — the manufacturing hub of China — we are equipped with advanced production facilities and a professional technical team, dedicated to providing high-quality precision hardware products and solutions for global clients.","heroCta1":"Partner With Us","heroCta2":"View Products","milestonesTitle":"Company Milestones","milestonesSubtitle":"From inception to today, Yonghejian has upheld the spirit of craftsmanship with continuous innovation and steady growth","milestone1Title":"Company Founded","milestone1Desc":"Yonghejian Precision Hardware Co., Ltd. established, focusing on mold design","milestone2Title":"Capacity Upgrade","milestone2Desc":"Introduced advanced CNC equipment, achieved mass production capability","milestone3Title":"Certification","milestone3Desc":"Obtained ISO9001 quality management system certification","milestone4Title":"Technology Innovation","milestone4Desc":"Awarded multiple national patents, driving smart manufacturing upgrades","valuesTitle":"Core Values","valuesSubtitle":"These values guide our decisions and actions every day","value1Title":"Quality First","value1Desc":"Adhering to a strict quality management system to ensure every product meets the highest standards","value2Title":"Continuous Improvement","value2Desc":"Relentlessly refining processes to pursue极致 precision and perfect quality","value3Title":"Integrity","value3Desc":"Building long-term, stable relationships with clients and partners based on trust","value4Title":"Innovation","value4Desc":"Exploring new technologies and processes to lead industry innovation and development","teamTitle":"Core Team","teamSubtitle":"An experienced professional team dedicated to your project's success","partnersSectionTitle":"Our Partner Network","partnersSectionSubtitle":"We collaborate with leading companies in materials, equipment, automation, and international trade to create reliable industrial solutions.","partnersPhilosophy1Title":"Collaborative Synergy","partnersPhilosophy1Desc":"We work closely with suppliers and industry partners to align resources and create complementary advantages.","partnersPhilosophy2Title":"Long-term Mutual Success","partnersPhilosophy2Desc":"Our partnerships focus on stability, shared growth, and sustainable development over the long term.","partnersPhilosophy3Title":"Value Creation","partnersPhilosophy3Desc":"Together we drive innovation, quality, and efficient supply-chain solutions for demanding manufacturing projects.","ctaTitle":"Let's Grow Together","ctaText":"Whether you're seeking a partner or technical consultation, we look forward to connecting with you","ctaButton1":"Contact Us","ctaButton2":"View Products"},"ContactPage":{"pageTitle":"Contact Us","pageSubtitle":"For precision hardware customization, mold development or partnership inquiries, feel free to reach out","formTitle":"Send an Inquiry","nameLabel":"Name","namePlaceholder":"Enter your name","nameError":"Name must be at least 2 characters","emailLabel":"Email","emailPlaceholder":"Enter your email","emailError":"Please enter a valid email address","phoneLabel":"Phone (optional)","phonePlaceholder":"Enter your phone number","companyLabel":"Company (optional)","companyPlaceholder":"Enter your company name","messageLabel":"Message","messagePlaceholder":"Describe your needs (mold customization, hardware processing, equipment procurement, import/export, etc.)","messageError":"Message must be at least 10 characters","submitText":"Submit Inquiry","submittingText":"Submitting...","successTitle":"Submitted Successfully!","successText":"Your inquiry has been sent successfully. We will contact you within 1-2 business days. Thank you for your trust!","resetButton":"Send Another Inquiry","infoTitle":"Contact Information","infoEmailLabel":"Email","infoPhoneLabel":"Phone","addressLabel":"Address","address":"Building 3, No. 103, Wangkeng Road, Dalingshan Town, Dongguan, Guangdong, China","hoursLabel":"Business Hours","hoursWeekday":"Monday - Friday: 8:00 - 18:00","hoursWeekend":"Saturday: 9:00 - 12:00 (Sunday closed)","faqTitle":"Frequently Asked Questions","faqSubtitle":"Questions you may have about our services and cooperation process","faq1Q":"What types of precision hardware services do you offer?","faq1A":"We offer one-stop services including precision hardware mold design and development, hardware component mass production, industrial machinery customization, non-standard precision hardware processing, and hardware product import/export trade.","faq2Q":"What is the custom mold process?","faq2A":"The process includes: requirements discussion and planning → 3D design and simulation → mold manufacturing and precision machining → trial molding and quality inspection → delivery and technical support.","faq3Q":"What is the minimum order quantity?","faq3A":"We support flexible solutions from small batch prototypes to large-scale production. Minimum order quantity depends on product complexity and process requirements. Please inquire about specific projects.","faq4Q":"What precision standards can you achieve?","faq4A":"Our precision machining accuracy reaches ±0.01mm, with higher precision customization available based on client requirements.","faq5Q":"How long is the typical production cycle?","faq5A":"Production cycles vary by complexity. Mold design and manufacturing typically takes 15-45 days, hardware component production 7-30 days. Specific timelines are determined during project evaluation.","faq6Q":"Do you provide after-sales service?","faq6A":"Yes, we provide comprehensive technical support and after-sales service, including mold maintenance guidance, technical consultation, and product usage training to ensure the best user experience."},"PartnersPage":{"pageTitle":"Our Partners","pageSubtitle":"Yonghejian has established long-term, stable partnerships with outstanding enterprises worldwide, jointly advancing the precision hardware industry","philosophyTitle":"Our Partnership Philosophy","philosophySubtitle":"Built on integrity, driven by mutual success","philosophy1Title":"Collaborative Synergy","philosophy1Desc":"Working closely with partners to integrate resources and achieve complementary advantages","philosophy2Title":"Long-term Mutual Success","philosophy2Desc":"Focusing on sustainable development with stable, reliable strategic partnerships","philosophy3Title":"Value Creation","philosophy3Desc":"Continuous innovation to create sustainable business value for our partners","advantagesTitle":"Why Partner With Us","advantagesSubtitle":"Choosing Yonghejian means comprehensive support and assurance","advantage1Title":"Professional Technical Support","advantage1Desc":"An experienced technical team providing full-cycle support from product design to mass production","advantage2Title":"Customized Solutions","advantage2Desc":"Personalized solutions tailored to client needs across different industries","advantage3Title":"Dedicated Service Team","advantage3Desc":"A dedicated project manager ensuring efficient communication and timely response","advantage4Title":"Strict Quality Control","advantage4Desc":"ISO9001 certified with comprehensive quality control throughout the entire process","advantage5Title":"Efficient Transparent Communication","advantage5Desc":"Transparent communication mechanisms ensuring real-time project progress updates","advantage6Title":"Supply Chain Integration","advantage6Desc":"Integrated upstream and downstream resources for cost optimization and efficiency improvement","ctaTitle":"Let's Partner for the Future","ctaText":"We look forward to building partnerships with more outstanding enterprises to advance the precision hardware industry","ctaButton":"Start Partnership"},"ProjectsPage":{"pageTitle":"Our Products","pageSubtitle":"Selected cases in precision hardware manufacturing, mold R&D and equipment customization showcasing our expertise","all":"All","category1":"Mold Design","category2":"Hardware Manufacturing","category3":"Equipment R&D","category4":"Custom Processing","category5":"International Trade","category6":"Technical Services","featuredBadge":"Featured Product","featuredTitle":"High-Precision Hardware Mold Customization","featuredDesc":"Custom precision hardware mold for a leading electronics manufacturer, achieving high-precision and high-efficiency production","featuredHighlight1":"Mold precision improved to 0.01mm","featuredHighlight2":"Production lead time reduced by 30%","featuredHighlight3":"Mold lifespan extended to over 500,000 cycles","featuredCta":"Request Customization","stepsTitle":"Service Process","stepsSubtitle":"From requirements to delivery, full-cycle professional service","step1Title":"Requirements Discussion","step1Desc":"In-depth understanding of client needs with professional recommendations","step2Title":"Solution Design","step2Desc":"Customized solutions with 3D modeling and simulation","step3Title":"Manufacturing","step3Desc":"Precision machining with strict quality control","step4Title":"Inspection & Delivery","step4Desc":"Comprehensive quality inspection and on-time delivery","ctaTitle":"Looking for Custom Hardware Solutions?","ctaText":"No matter the size of your project, we provide professional technical support and quality service","ctaButton":"Inquire Now"},"ProjectDetail":{"backLink":"Back to Products List"},"Footer":{"brand":"Yonghejian | Precision Hardware","description":"Specializing in precision hardware mold design, development, production and sales, dedicated to providing high-quality products and solutions for global clients","navTitle":"Navigation","businessTitle":"Core Business","business1":"Precision Mold Design","business2":"Hardware Component Manufacturing","business3":"Machinery Equipment R&D","business4":"Import & Export Trade","business5":"Custom Processing","contactTitle":"Contact","address":"Building 3, No. 103, Wangkeng Road, Dalingshan Town, Dongguan, Guangdong, China","established":"Established: September 21, 2016","copyright":"© 2024 Dongguan Yonghejian Precision Hardware Co., Ltd. All rights reserved","privacy":"Privacy Policy","terms":"Terms of Service"},"NotFound":{"heading":"Page Not Found","description":"The page you are looking for doesn't exist, may have been moved, or the link has expired. Please check the address or return to the homepage.","home":"Back to Home","back":"Go Back","metaTitle":"404 - Page Not Found | Yonghejian Precision Hardware","metaDescription":"The page you requested could not be found. Return to the Yonghejian homepage or go back to the previous page."}},"now":"$undefined","timeZone":"Asia/Shanghai","children":["$","div",null,{"className":"flex min-h-screen flex-col","children":[["$","$Lb",null,{}],["$","main",null,{"className":"flex-1","children":["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children",["locale","en","d"],"children"],"loading":"$undefined","loadingStyles":"$undefined","hasLoading":false,"error":"$undefined","errorStyles":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","childProp":{"current":["$Lc","$Ld",null],"segment":"__PAGE__?{\"locale\":\"en\"}"},"styles":[]}]}],"$Le"]}]}]
